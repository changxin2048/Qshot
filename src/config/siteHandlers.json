{
  "sites": [
    {
      "id": "chatgpt",
      "name": "ChatGPT",
      "url": "https://chatgpt.com/",
      "enabled": true,
      "supportIframe": true,
      "supportUrlQuery": false,
      "matchPatterns": [
        "chatgpt.com",
        "chat.openai.com"
      ],
      "notes": "优先在页面内 iframe 卡片中加载 ChatGPT，若目标站点仍拦截嵌入则显示受限提示。",
      "searchHandler": {
        "submitVerifyWaitMs": 1600,
        "submitVerifyRetries": 4,
        "steps": [
          {
            "action": "focus",
            "selectors": [
              "#prompt-textarea",
              "div[contenteditable='true']",
              "textarea"
            ],
            "timeout": 10000,
            "description": "聚焦输入框（等待页面就绪）"
          },
          {
            "action": "setValue",
            "selectors": [
              "#prompt-textarea",
              "div[contenteditable='true']",
              "textarea"
            ],
            "inputType": "auto",
            "maxAttempts": 20,
            "stableWaitMs": 800,
            "description": "写入查询内容（execCommand insertText 会派发原生 input 事件同步 React 状态）"
          },
          {
            "action": "smartSubmit",
            "selectors": [
              "#prompt-textarea",
              "div[contenteditable='true']",
              "textarea"
            ],
            "submitSelectors": [
              "button[data-testid='send-button']",
              "button[data-testid*='send']",
              "button[aria-label*='Send']",
              "button[aria-label*='Submit']",
              "button[aria-label*='发送']",
              "button[type='submit']"
            ],
            "submitWaitMs": 6000,
            "postClickVerifyMs": 1400,
            "description": "轮询发送按钮由 aria-disabled 切换为可用后立即点击（ChatGPT 冷启动水合较慢，等长一点）"
          },
          {
            "action": "sendKeys",
            "selectors": [
              "#prompt-textarea",
              "div[contenteditable='true']",
              "textarea"
            ],
            "keys": [
              "Enter"
            ],
            "optional": true,
            "description": "回车作为最终备用发送方式"
          }
        ]
      }
    },
